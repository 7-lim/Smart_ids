# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/

# --- Virtual envs ---
ids_pfa/
.venv/
venv/
env/

# --- Data ---
# Heavy CSVs are ignored, but the tiny metadata JSONs under
# data/cicids2017/features/ are tracked so a fresh clone can run the
# predictor without re-running notebook 01.
data/cicids2017/raw/
data/cicids2017/processed/
data/cicids2017/balanced/

# --- Models ---
# Trained artifacts are SHIPPED in git (only ~3 MB total) so the cyber
# team can run inference immediately without retraining. Anything else
# that ends up in models/ (experimental snapshots, temp checkpoints) is
# ignored to keep the repo clean.
models/*.h5
models/checkpoints/
models/tmp_*

# --- IDE / OS ---
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db

# --- Notebook output noise ---
*.nbconvert.ipynb

# --- Report deliverable (not part of the codebase) ---
# Generated LaTeX report and its image folder are delivered separately
# (Overleaf project / academic submission), not tracked in the repo.
rapport.txt
img/

# --- One-shot helper scripts (must never be committed) ---
_fix_*.py
_extract_*.py
